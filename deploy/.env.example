# Copy to deploy/.env on the deploy host (electron-server).

# Image tag (used by docker-compose). Bump on each release.
TAG=latest

# Traefik cert resolver name (must match the one configured on the host's
# traefik instance). On electron-server it's typically "letsencrypt".
TRAEFIK_CERTRESOLVER=letsencrypt

# ailiance gateway URL. Default points to the host's :9300 (LiteLLM router on
# electron-server). Override only if you move the gateway to another box.
COCKPIT_AILIANCE_GATEWAY_URL=http://host.docker.internal:9300

# Collector base URL (kiki-collector running on studio — Tailscale Magic DNS).
COCKPIT_COLLECTOR_BASE_URL=http://studio:9150

# Logging
COCKPIT_LOG_LEVEL=INFO

# HF token (optional, raises HF API rate limit).
HF_TOKEN=

# Published Grist review-doc URL embedded by the cockpit-admin
# "Review Datasets" page. Leave empty to show the not-configured
# fallback instead of the iframe.
VITE_GRIST_URL=
